{
  "name": "Node.js and pnpm stuffs",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",
  "features": {
  },

  "postCreateCommand": "corepack enable && corepack prepare pnpm@latest --activate",
  "postStartCommand": "bash -lc 'corepack enable && pnpm install --prefer-offline && nohup pnpm dev --host 0.0.0.0 >/tmp/pnpm-dev.log 2>&1 &'",
  "forwardPorts": [5173],
  "portsAttributes": {
    "5173": {
      "label": "Vite Preview",
      "onAutoForward": "openPreview"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss"
      ]
    }
  }
}